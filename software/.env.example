# ─── Django ──────────────────────────────────────────────────────────────────
DJANGO_SETTINGS_MODULE=config.settings.local
DJANGO_SECRET_KEY=change-me-in-production-this-is-not-secret
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend

# ─── Database ────────────────────────────────────────────────────────────────
POSTGRES_DB=micromouse
POSTGRES_USER=micromouse
POSTGRES_PASSWORD=micromouse
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ─── Redis / Celery ──────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ─── MinIO (S3-compatible) ───────────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ENDPOINT=http://minio:9000
MINIO_BUCKET=micromouse-artifacts

# ─── CORS ────────────────────────────────────────────────────────────────────
# Lista CSV de origens permitidas. Case-sensitive, sem trailing slash, com schema.
# Em prod: liberar SÓ o domínio real do frontend. Nunca CORS_ALLOW_ALL_ORIGINS=True.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_ACCESS_LIFETIME_MINUTES=60
JWT_REFRESH_LIFETIME_DAYS=7

# ─── Observabilidade ─────────────────────────────────────────────────────────
# Sentry é opt-in: DSN vazio = desligado. Populado = liga (Django + Celery).
SENTRY_DSN=
SENTRY_ENVIRONMENT=local
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_RELEASE=

# Logging: pretty (texto colorido) em dev; json (uma linha por evento) em prod.
LOG_LEVEL=INFO
LOG_MODE=pretty

# ─── Frontend (Vite) ─────────────────────────────────────────────────────────
# Default '/api' (proxy via vite). Override só em prod.
VITE_API_BASE_URL=
